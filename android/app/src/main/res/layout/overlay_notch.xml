<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notchPill"
    android:layout_width="wrap_content"
    android:layout_height="44dp"
    android:background="@drawable/notch_pill_bg"
    android:elevation="24dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="8dp">

    <!-- Pulsing dot — green when running, white when done -->
    <View
        android:id="@+id/notchDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/dot_green" />

    <!-- Task description -->
    <TextView
        android:id="@+id/tvNotchTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:maxWidth="210dp"
        android:textColor="#FFFFFF"
        android:textSize="12.5sp" />

    <!-- Cancel button -->
    <ImageButton
        android:id="@+id/btnNotchCancel"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Stop task"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#CCCCCC" />

</LinearLayout>
