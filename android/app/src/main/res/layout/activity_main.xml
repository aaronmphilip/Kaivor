<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#0D0D0D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BharatDroid"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your AI agent. Runs on your phone."
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="40dp" />

        <!-- Telegram Bot Token -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Telegram Bot Token"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="123456:ABC-DEF..."
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:layout_marginBottom="20dp" />

        <!-- Claude API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Claude API Key"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etClaudeKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:layout_marginBottom="20dp" />

        <!-- Telegram Chat ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Telegram Chat ID"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message @userinfobot on Telegram to get your ID"
            android:textColor="#555555"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="123456789"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:layout_marginBottom="28dp" />

        <!-- Accessibility Service -->
        <TextView
            android:id="@+id/tvAccessibilityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✗ Accessibility Service: Not connected"
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Accessibility Service"
            android:backgroundTint="#1E1E1E"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="28dp" />

        <!-- Start Button -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Agent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FF4500"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00CC88"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
