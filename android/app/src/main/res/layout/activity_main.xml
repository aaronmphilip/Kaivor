<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top orange accent strip -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#FF5C00"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="40dp">

            <!-- ── Header row ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <!-- Logo + wordmark -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_logo_mark"
                        android:contentDescription="BharatDroid logo"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BharatDroid"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Phone Agent"
                            android:textColor="#FF5C00"
                            android:textSize="11sp"
                            android:layout_marginTop="1dp"/>
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Settings"
                    android:backgroundTint="#111111"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"/>
            </LinearLayout>

            <!-- ── Stat strip row 1 (Commands · Skills · Uptime) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- Commands today -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_stat"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCommandCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FF5C00"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Commands"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <!-- Skills active -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_stat"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvStatSkills"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25"
                        android:textColor="#FF5C00"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skills"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <!-- Uptime -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_stat"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvUptime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FF5C00"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uptime"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Capability badges row (Voice · Vision · Files · STT) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <!-- Voice / STT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_stat"
                    android:padding="10dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎙️"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/tvSttStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voice"
                        android:textColor="#00CC88"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="6dp" android:layout_height="1dp"/>

                <!-- Vision / Screenshot -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_stat"
                    android:padding="10dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👁️"
                        android:textSize="18sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vision"
                        android:textColor="#00CC88"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="6dp" android:layout_height="1dp"/>

                <!-- File Share -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_stat"
                    android:padding="10dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📂"
                        android:textSize="18sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Files"
                        android:textColor="#00CC88"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="6dp" android:layout_height="1dp"/>

                <!-- Notifications -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_stat"
                    android:padding="10dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/tvNotifBadgeMini"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifs"
                        android:textColor="#555555"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Status Card (orange border) ── -->
            <LinearLayout
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_orange_accent"
                android:padding="20dp"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_green"/>

                    <TextView
                        android:id="@+id/tvAgentStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Agent Running"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAccessibilityStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Accessibility: Connected"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/tvSkillCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Skills loaded"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp"/>

                <TextView
                    android:id="@+id/tvTodayCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 commands today"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp"/>

                <Button
                    android:id="@+id/btnToggleAgent"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Stop Agent"
                    android:backgroundTint="#1A0800"
                    android:textColor="#FF5C00"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"/>
            </LinearLayout>

            <!-- ── Notification Relay Card ── -->
            <LinearLayout
                android:id="@+id/cardCurrentTask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvTaskStatusTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Current task"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvTaskProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Idle"
                    android:textColor="#FF5C00"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvTaskMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No task running"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.35"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardNotifRelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_premium"
                android:padding="18dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔔  Notification Relay"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        />

                    <TextView
                        android:id="@+id/tvNotifRelayBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OFF"
                        android:textColor="#FF6B6B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_bg"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvNotifRelayDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Every app notification → your Telegram. Reply in Telegram → reply in the app."
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:id="@+id/btnEnableNotifRelay"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="Enable Notification Access"
                    android:backgroundTint="#111111"
                    android:textColor="#FF5C00"
                    android:textSize="12sp"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- ── Quick commands hint card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬  How to use"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send any message to your Telegram bot. Type or record a voice note."
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🍕 &quot;Order pizza from Swiggy&quot;"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📂 &quot;Share report.pdf to Rahul on WhatsApp&quot;"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🎙️ Record a voice note — I'll transcribe and execute it"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📄 &quot;Read the PDF in Downloads fully&quot;"
                        android:textColor="#888888"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Skills section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Skills"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap Telegram to use →"
                    android:textColor="#444444"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/skillsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"/>

            <!-- ── Recent Activity section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Activity"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last 8 commands"
                    android:textColor="#444444"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activityList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="12dp"
                android:layout_marginTop="10dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
