<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#FF5C00"/>

        <!-- Step indicator -->
        <TextView
            android:id="@+id/tvStepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 5"
            android:textColor="#FF5C00"
            android:textSize="12sp"
            android:layout_marginTop="20dp" />

        <!-- ═══════════════════════════════════ -->
        <!--  STEP 1: Welcome                   -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="60dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BharatDroid"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your AI agent that controls your phone.\nTell it what to do via Telegram.\nIt does the rest."
                android:textColor="#AAAAAA"
                android:textSize="16sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&quot;Order biryani from Swiggy under ₹200&quot;\n&quot;Recharge my phone ₹239 on PhonePe&quot;\n&quot;Navigate to Connaught Place&quot;\n&quot;Play Arijit Singh on YouTube&quot;"
                android:textColor="#00CC88"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:fontFamily="monospace"
                android:layout_marginTop="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Setup takes 2 minutes. No coding required."
                android:textColor="#666666"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="32dp" />

            <Button
                android:id="@+id/btnGetStarted"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Get Started"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#FF5C00"
                android:textColor="#FFFFFF"
                android:layout_marginTop="40dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!--  STEP 2: Telegram Bot Token        -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Your Telegram Bot"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is how you&apos;ll talk to your agent.\n\n1. Open Telegram\n2. Search for @BotFather\n3. Send /newbot\n4. Choose a name (e.g. &quot;My Agent&quot;)\n5. Choose a username (e.g. &quot;myagent_bot&quot;)\n6. Copy the token it gives you"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnOpenBotFather"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Open @BotFather in Telegram"
                android:backgroundTint="#1E1E1E"
                android:textColor="#00AAFF"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paste the bot token here:"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etBotToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="123456:ABC-DEF1234ghIkl..."
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:fontFamily="monospace"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTokenStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnVerifyToken"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Verify Token"
                android:textSize="15sp"
                android:backgroundTint="#FF5C00"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!--  STEP 3: Auto-detect Chat ID       -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/step3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pair Your Account"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPairInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Now open Telegram and send /start to your bot.\n\nWaiting..."
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="16dp" />

            <ProgressBar
                android:id="@+id/progressPairing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:indeterminateTint="#FF4500" />

            <TextView
                android:id="@+id/tvPairResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#00CC88"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnOpenBot"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Open Your Bot in Telegram"
                android:backgroundTint="#1E1E1E"
                android:textColor="#00AAFF"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnStep3Next"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Continue"
                android:textSize="15sp"
                android:backgroundTint="#FF5C00"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!--  STEP 4: Claude API Key            -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/step4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect AI Brain"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose your AI provider. Gemini is FREE."
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:layout_marginTop="16dp" />

            <!-- Provider toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnPickGemini"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Gemini"
                    android:textSize="11sp"
                    android:backgroundTint="#1A73E8"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnPickClaude"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Claude"
                    android:textSize="11sp"
                    android:backgroundTint="#1E1E1E"
                    android:textColor="#AAAAAA"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnPickOpenAI"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="ChatGPT"
                    android:textSize="11sp"
                    android:backgroundTint="#1E1E1E"
                    android:textColor="#AAAAAA"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAIInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Go to aistudio.google.com/apikey\n2. Sign in with Google\n3. Click 'Create API Key'\n4. Copy and paste below"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnOpenClaude"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Get Free Gemini API Key"
                android:backgroundTint="#1E1E1E"
                android:textColor="#00AAFF"
                android:layout_marginTop="12dp" />

            <!-- Permission Mode -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Agent Mode:"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ask Permission = confirms before acting\nJust Do It = executes immediately, no questions"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnAskPermission"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Ask Permission"
                    android:backgroundTint="#00CC88"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnJustDoIt"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Just Do It"
                    android:backgroundTint="#1E1E1E"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paste API key:"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etClaudeKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="sk-ant-api03-..."
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:fontFamily="monospace"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnStep4Next"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Continue"
                android:textSize="15sp"
                android:backgroundTint="#FF5C00"
                android:textColor="#FFFFFF"
                android:layout_marginTop="20dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!--  STEP 5: Accessibility + Launch     -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/step5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="One Last Step"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Permission 1: Accessibility -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Accessibility Access (required)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lets BharatDroid control apps on your behalf — tap, type, scroll."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvAccessStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ Not enabled"
                android:textColor="#FF6B6B"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnEnableAccess"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Open Accessibility Settings"
                android:backgroundTint="#1E1E1E"
                android:textColor="#FFFFFF"
                android:layout_marginTop="6dp" />

            <!-- Permission 2: Notification Access -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Notification Access (for 24×7 relay)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Forwards every app notification to your Telegram. Reply in Telegram to reply in the app.\n\nOptional — skip if you don't want this."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvNotifStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ Not enabled"
                android:textColor="#FF6B6B"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnEnableNotifAccess"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Open Notification Access Settings"
                android:backgroundTint="#1E1E1E"
                android:textColor="#FFFFFF"
                android:layout_marginTop="6dp" />

            <!-- Permission 3: Overlay (Notch) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Floating Notch Overlay (recommended)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shows a black pill on screen while tasks run. Tap × to cancel instantly. Drag it anywhere."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvOverlayStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✗ Not granted"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnGrantOverlayOnboard"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Grant Display Over Other Apps"
                android:backgroundTint="#1E1E1E"
                android:textColor="#FFFFFF"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnStep5Next"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Continue"
                android:textSize="15sp"
                android:backgroundTint="#FF5C00"
                android:textColor="#FFFFFF"
                android:layout_marginTop="32dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════ -->
        <!--  STEP 6: Power Features + Launch   -->
        <!-- ═══════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/step6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Power Features"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="These make BharatDroid 10× more powerful. All optional."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <!-- ── Phone Setup Type ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Is this your second/dedicated AI phone?"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This helps us set up call answering and forwarding correctly."
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnPhoneTypeDedicated"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="Yes, 2nd Phone"
                    android:textSize="13sp"
                    android:backgroundTint="#1E1E1E"
                    android:textColor="#AAAAAA"
                    android:layout_marginEnd="6dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnPhoneTypeMain"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="No, My Main Phone"
                    android:textSize="13sp"
                    android:backgroundTint="#1E1E1E"
                    android:textColor="#AAAAAA"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Dedicated phone guidance (shown when 2nd phone selected) -->
            <LinearLayout
                android:id="@+id/layoutDedicatedPhoneGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="#0D1A0D"
                android:padding="14dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅  Dedicated AI Phone Setup"
                    android:textColor="#00CC88"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Does this phone have an active SIM that can receive calls?"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnSimYes"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Yes, it can"
                        android:textSize="12sp"
                        android:backgroundTint="#1E1E1E"
                        android:textColor="#AAAAAA"
                        android:layout_marginEnd="6dp"
                        android:stateListAnimator="@null" />

                    <Button
                        android:id="@+id/btnSimNo"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="No / WiFi only"
                        android:textSize="12sp"
                        android:backgroundTint="#1E1E1E"
                        android:textColor="#AAAAAA"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- SIM Yes guidance -->
                <LinearLayout
                    android:id="@+id/layoutSimYesGuide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Great! This phone can AI-answer any call made to its number.\n\nTo also forward calls from your main number to this phone:\n  1. On your MAIN phone → open Phone app\n  2. Settings → Call Forwarding (or Supplementary services)\n  3. Set 'Forward all calls' to this phone's number\n  4. Your callers dial your main number — this phone's AI answers\n\nOr just share this phone's number directly as your business/AI line."
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="After setup: go to Settings → AI Call Answering → set your name, ElevenLabs voice, VIP numbers."
                        android:textColor="#00CC88"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <!-- SIM No guidance -->
                <LinearLayout
                    android:id="@+id/layoutSimNoGuide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No problem. You can still use BharatDroid for:\n  • All Telegram-based commands (no SIM needed)\n  • Notification relay via WiFi\n  • WhatsApp channel commands\n  • Research, routines, macros\n\nAI call answering requires an active SIM to receive calls."
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>

            <!-- Main phone guidance (shown when main phone selected) -->
            <LinearLayout
                android:id="@+id/layoutMainPhoneGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="#0D1A0D"
                android:padding="14dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱  Main Phone — Recommended Setup"
                    android:textColor="#00CC88"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Notification relay recommendation -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔔  Option 1 — Notification Relay (Recommended)"
                    android:textColor="#FFCC00"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Don't want to change your default Phone app? Use Notification Relay instead:\n\n  • Every call that comes in shows up in Telegram\n  • You see the caller name, missed calls, voicemails\n  • Reply directly from Telegram to any app's notifications\n  • Your normal Phone app stays exactly as it is\n\nEnable in Settings → Notifications → Device &amp; App Notifications → BharatDroid → Allow."
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="6dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A2A"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- AI call answering option -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🤖  Option 2 — AI Call Answering (Power Mode)"
                    android:textColor="#FF5C00"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Want AI to answer calls on your behalf? Set BharatDroid as your default Phone app in Settings → AI Call Answering.\n\nWhat you get:\n  • BharatDroid becomes your Phone app — its own dialer for outgoing calls\n  • Incoming calls: AI answers, speaks in your cloned voice, live-transcripts to Telegram\n  • VIP callers (family, boss) skip AI — you get an urgent Telegram alert instead\n  • Tap \'Take Over\' in the notification to jump into any call live\n  • After every call: full transcript + AI summary sent to Telegram\n\n⚠️  Your normal Phone app stays installed — you can still open it for contacts and recents. Calls will just go through BharatDroid\'s dialer.\n\nFor outgoing calls: use BharatDroid\'s dialer or say in Telegram:\n&quot;call Rahul about the invoice&quot; → AI makes the call for you."
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Agent Mode -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Agent Mode"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚡ Efficient — saves API credits, fast, great for everyday tasks.\n🔥 Ultra — goes all out. Vision on every step. Full context. Best results."
                android:textColor="#888888"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnOnboardEfficient"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="⚡ Efficient"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#00CC88"
                    android:textColor="#000000"
                    android:layout_marginEnd="6dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnOnboardUltra"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="🔥 Ultra"
                    android:textSize="13sp"
                    android:backgroundTint="#1E1E1E"
                    android:textColor="#AAAAAA"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- WhatsApp Channel -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WhatsApp Channel (optional)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Install WhatsApp Business on this phone with a second SIM. Enter that number below. Message it from your main WhatsApp to give commands. Leave blank to skip."
                android:textColor="#888888"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="6dp" />

            <EditText
                android:id="@+id/etOnboardWaNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+91XXXXXXXXXX (leave blank to skip)"
                android:inputType="phone"
                android:textColor="#FFFFFF"
                android:textColorHint="#444444"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:layout_marginTop="10dp" />

            <!-- Launch -->
            <Button
                android:id="@+id/btnLaunchAgent"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Launch BharatDroid"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#FF5C00"
                android:textColor="#FFFFFF"
                android:layout_marginTop="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your data never leaves your phone.\nNo account. No tracking. All local."
                android:textColor="#555555"
                android:textSize="12sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
