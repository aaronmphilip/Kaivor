NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://username:password@localhost:5432/bharatclaw
MASTER_API_KEY=replace-with-strong-master-key
APP_BASE_URL=http://localhost:3000

TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret-token
OWNER_CONNECT_BOT_TOKEN=replace-with-owner-connect-bot-token
OWNER_CONNECT_BOT_SECRET=replace-with-owner-connect-secret
OWNER_CONNECT_BOT_USERNAME=bharatclawbot
AI_AGENT_ENABLED=false
AI_AGENT_API_KEY=replace-with-openai-compatible-api-key
AI_AGENT_MODEL=replace-with-model-id
AI_AGENT_API_URL=https://api.openai.com/v1/chat/completions
AI_AGENT_SYSTEM_PROMPT=

POLAR_ACCESS_TOKEN=replace-with-polar-api-token
POLAR_WEBHOOK_SECRET=replace-with-polar-webhook-secret
POLAR_PRODUCT_ID=replace-with-polar-product-id
POLAR_MONTHLY_PRICE_INR=1499

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=noreply@bharatclaw.in

FOLLOWUP_POLL_INTERVAL_MS=60000
FOLLOWUP_MAX_RETRIES=3
FREE_MODE=true
PUBLIC_SIGNUP_ENABLED=true
LANDING_CTA_URL=https://bharatclawapp.vercel.app/get-started

# Optional Cloudflare Worker secrets
# MASTER_API_KEY and TELEGRAM_WEBHOOK_SECRET are required in Cloudflare too (via wrangler secret put)
# For Cloudflare local dev, add these keys to .dev.vars (see .dev.vars.example)
# AI_AGENT_* can also be set on the worker to enable AI reply drafts, lead briefs, and workspace copilot advice.
