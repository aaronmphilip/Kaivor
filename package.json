{
  "name": "bharatclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:worker": "tsx apps/worker/src/worker.ts",
    "dev:cf": "npx wrangler dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:worker\"",
    "deploy:cf": "npx wrangler deploy",
    "cf:migrate:local": "npx wrangler d1 execute bharatclaw --local --file=sql/d1_init.sql",
    "cf:migrate:remote": "npx wrangler d1 execute bharatclaw --remote --file=sql/d1_init.sql",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "psql \"$DATABASE_URL\" -f sql/001_init.sql",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
